root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{c,h,cpp,hpp,cc,hh}]
indent_style = space
indent_size = 4

[*.{v,vh,sv,svh}]
indent_style = space
indent_size = 4

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 4

[*.{ini,conf}]
indent_style = space
indent_size = 4

[*.{json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.{xml,xsd}]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false


// The tab world
[*.{go}]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.tsv]
indent_style = tab
trim_trailing_whitespace = false
